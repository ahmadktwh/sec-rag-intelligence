# ═══════════════════════════════════════════════
# SEC EDGAR RAG System — .gitignore
# ═══════════════════════════════════════════════

# ── CRITICAL: Never commit these ───────────────
.env
*.env
.env.local
.env.production
.env.staging

# ── Python ─────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/

# ── Virtual Environments ────────────────────────
venv/
.venv/
env/
ENV/

# ── IDE ─────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── Data & Downloads ────────────────────────────
data/raw_filings/
data/cache/
*.pdf
# Strictly exclude all PDFs from the repo

# ── Project internals & Planning ────────────────
blueprint_content.txt
plan.txt
checkpoint*.txt
_project_management/
*.pdf
*.docx
*.txt
!requirements.txt

# ── Logs ─────────────────────────────────────────
*.log
logs/

# ── OS ───────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Testing ───────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/

# ── Docker ────────────────────────────────────────
# docker-compose.override.yml

# ── Node.js / Frontend ───────────────────────────
frontend/node_modules/
frontend/dist/
frontend/.env

# ── Misc ─────────────────────────────────────────
*.txt
!requirements.txt
