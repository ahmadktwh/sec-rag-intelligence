# ══════════════════════════════════════════════════════
# SEC EDGAR Financial Intelligence System — Environment
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
# ══════════════════════════════════════════════════════

# ── AI Model Configuration (Required) ──────────────────
# LiteLLM model string — choose any supported provider
# Examples:
#   Google:    gemini/gemini-2.5-pro
#   OpenAI:    gpt-4o
#   Anthropic: claude-3-5-sonnet-20241022
#   Mistral:   mistral/mistral-large
#   Local:     ollama/llama3 (no API key needed)
LLM_MODEL=gemini/gemini-2.5-pro

# ── API Keys (provide the one matching your LLM_MODEL) ─
GOOGLE_API_KEY=your_google_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
MISTRAL_API_KEY=your_mistral_api_key_here

# ── Pinecone Vector Database (Required) ────────────────
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_INDEX_NAME=sec-rag-intelligence

# ── Redis Cache (Optional — system works without it) ───
REDIS_HOST=localhost
REDIS_PORT=6379

# ── LangSmith Observability (Optional) ─────────────────
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=sec-rag-intelligence
